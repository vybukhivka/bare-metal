{
    "configurations": [
        {
            "name": "ST-Link: Debug Application",
            "cwd": "${workspaceFolder}/app",
            "executable": "./firmware.elf",
            "servertype": "stutil",
            "request": "launch",
            "type": "cortex-debug",
            "device": "STM32L476RG",
            "runToEntryPoint": "main",
            "interface": "swd",
            "preLaunchTask": "build_debug",
            "gdbPath": "/usr/bin/gdb",
            "armToolchainPath": "/usr/bin"
        },
        {
            "name": "ST-Link: Debug Bootloader",
            "cwd": "${workspaceFolder}/bootloader",
            "executable": "./bootloader.elf",
            "servertype": "stutil",
            "request": "launch",
            "type": "cortex-debug",
            "device": "STM32L476RG",
            "runToEntryPoint": "main",
            "interface": "swd",
            "preLaunchTask": "build_bootloader",
            "gdbPath": "/usr/bin/gdb",
            "armToolchainPath": "/usr/bin"
        },
        {
            "name": "ST-Link: Attach to Application",
            "cwd": "${workspaceFolder}/app",
            "executable": "./firmware.elf",
            "servertype": "stutil",
            "request": "attach",
            "type": "cortex-debug",
            "device": "STM32L476RG",
            "runToEntryPoint": "main",
            "interface": "swd"
        },
        {
            "name": "ST-Link: Attach to Bootloader",
            "cwd": "${workspaceFolder}/bootloader",
            "executable": "./bootloader.elf",
            "servertype": "stutil",
            "request": "attach",
            "type": "cortex-debug",
            "device": "STM32L476RG",
            "runToEntryPoint": "main",
            "interface": "swd"
        }
    ]
}
